{
  "expo": {
    "name": "fishBuddyV2",
    "slug": "fishBuddyV2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fishbuddyv2",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permissions.CAMERA",
        "android.permissions.READ_EXTERNAL_STORAGE",
        "android.permissions.WRITE_EXTERNAL_STORAGE",
        "android.permissions.ACCESS_COARSE_LOCATION",
        "android.permissions.ACCESS_FINE_LOCATION"
      ],
      "package": "com.shipy.FishBuddyCL"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "La aplicación necesita acceder a tu galería para seleccionar imagenes guardadas",
          "cameraPermission": "La aplicación necesita acceder a tu cámara para poder tomar imágenes"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Fish buddy necesita acceder a tu localización para registrar el lugar de captura"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
